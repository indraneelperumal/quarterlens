# Anthropic (agent reasoning)
ANTHROPIC_API_KEY=

# Market data (primary: FMP free tier)
FMP_API_KEY=

# Market data fallback + news sentiment scoring
ALPHA_VANTAGE_API_KEY=

# Real-time financial news search (free tier: 1000 req/mo — tavily.com)
TAVILY_API_KEY=

# SEC EDGAR — required User-Agent format: "Name email@domain.com"
SEC_EDGAR_USER_AGENT=EarningsAgent your@email.com

# Qdrant (local via docker-compose)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=financial_docs

# Embeddings (optional; local sentence-transformers used if unset)
OPENAI_API_KEY=

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Next.js (copy to apps/web/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8000
